# ============================================
# OAuth2 Configuration
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# JWT Configuration
# ============================================
# Must be at least 32 bytes (256 bits) for HS256
JWT_SECRET=your-jwt-secret-key-that-is-long-enough-for-hs256-algorithm-minimum-32-bytes
JWT_EXPIRATION_MS=3600000

# ============================================
# Google APIs Configuration
# ============================================
GOOGLE_GMAIL_BASE_URL=https://gmail.googleapis.com/gmail/v1
GOOGLE_GMAIL_USER_ID=me
GOOGLE_GMAIL_MAX_RESULTS=10
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_MAX_RESULTS=10
GOOGLE_DRIVE_BASE_URL=https://www.googleapis.com/drive/v3
GOOGLE_DRIVE_MAX_RESULTS=10

# ============================================
# LLM Provider Configuration
# ============================================
LLM_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ============================================
# Database Configuration
# ============================================
DB_NAME=lifeos
DB_USER=lifeos
DB_PASSWORD=lifeos
DB_HOST=localhost
DB_PORT=5432

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# ============================================
# Application Logging
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_FAMILYOS=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG
LOGGING_LEVEL_ORG_FLYWAYDB=INFO
