{
  "info": {
    "name": "FamilyOS Phase 3 – LLM Foundation",
    "description": "Postman collection for Phase 3 LLM Foundation API endpoints. Tests multi-provider LLM integration (Gemini, Groq, OpenRouter). Import the main FamilyOS_API collection and set base_url and token environment variables before using. See docs/development/phase3-api-testing.md for authentication setup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "LLM – Phase 3",
      "item": [
        {
          "name": "Health Check – Default Provider",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "JWT token from OAuth login. See phase3-api-testing.md for setup"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/llm/health",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "health"]
            },
            "description": "Check health status of the default LLM provider (configured via LLM_DEFAULT_PROVIDER environment variable)"
          },
          "response": []
        },
        {
          "name": "Generate – Default Provider",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text",
                "description": "JWT token from OAuth login"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"systemPrompt\": \"You are a helpful assistant. Be concise and direct.\",\n  \"userPrompt\": \"What are the top 3 features of LifeOS?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Generate LLM response using default provider (systemPrompt and userPrompt required)"
          },
          "response": []
        },
        {
          "name": "Generate – Explicit Gemini",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"systemPrompt\": \"You are a helpful assistant. Be concise and direct.\",\n  \"userPrompt\": \"What is Gemini?\",\n  \"provider\": \"gemini\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Generate LLM response explicitly using Gemini provider (optional provider parameter overrides default)"
          },
          "response": []
        },
        {
          "name": "Generate – Explicit Groq",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"systemPrompt\": \"You are a helpful assistant. Be concise and direct.\",\n  \"userPrompt\": \"What is Groq?\",\n  \"provider\": \"groq\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Generate LLM response explicitly using Groq provider (optional provider parameter overrides default)"
          },
          "response": []
        },
        {
          "name": "Generate – Explicit OpenRouter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
