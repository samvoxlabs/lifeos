            "body": {
              "mode": "raw",
              "raw": "{\n  \"systemPrompt\": \"You are a helpful assistant. Be concise and direct.\",\n  \"userPrompt\": \"What is OpenRouter?\",\n  \"provider\": \"openrouter\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Generate LLM response explicitly using OpenRouter provider (optional provider parameter overrides default)"
          },
          "response": []
        }
      ]
    },
