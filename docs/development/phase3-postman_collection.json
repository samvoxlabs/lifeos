    {
      "name": "Error Handling Tests",
      "item": [
        {
          "name": "Error – Missing systemPrompt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userPrompt\": \"This should fail due to missing systemPrompt\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Expected: 400 Bad Request (systemPrompt is required)"
          },
          "response": []
        },
        {
          "name": "Error – Missing userPrompt",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"systemPrompt\": \"You are a helpful assistant.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Expected: 400 Bad Request (userPrompt is required)"
          },
          "response": []
        },
        {
          "name": "Error – Invalid Provider",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"systemPrompt\": \"You are a helpful assistant.\",\n  \"userPrompt\": \"This should fail due to invalid provider\",\n  \"provider\": \"invalid_provider\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/llm/generate",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "llm", "generate"]
            },
            "description": "Expected: 400 Bad Request (provider not found)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL for the API. Default is localhost:8080. Change if using different port (SERVER_PORT env var)."
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token from OAuth login. Follow steps in docs/development/phase3-api-testing.md to get token from http://localhost:8080/oauth2/authorization/google"
    }
  ]
