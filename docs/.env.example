# Example .env file for local development
# Copy this to `.env` and fill in real values. DO NOT commit secrets to the repository.

# Google OAuth (example keys used in this project)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Spring Boot profile (optional)
SPRING_PROFILES_ACTIVE=local

# Server port override (optional)
SERVER_PORT=8080

# Example database placeholder (if added in future)
# DATABASE_URL=jdbc:postgresql://localhost:5432/familyos
# DATABASE_USER=
# DATABASE_PASSWORD=

