              "mode": "raw",
              "raw": "{\n  \"sourceDocument\": {\n    \"id\": \"doc-2\",\n    \"sender\": \"important@school.org\",\n    \"subject\": \"Meeting reminder\",\n    \"content\": \"Meeting next Friday at 3 PM\",\n    \"labels\": [\"school\"],\n    \"priority\": \"high\",\n    \"source\": \"email\",\n    \"provider\": \"google\",\n    \"sourceType\": \"gmail\",\n    \"externalId\": \"msg-2\",\n    \"rawContent\": \"Meeting next Friday at 3 PM\",\n    \"metadata\": {}\n  }\n}"
