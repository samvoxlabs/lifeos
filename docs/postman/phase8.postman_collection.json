{
  "info": {
    "_postman_id": "phase8-mailbox-apis",
    "name": "Phase 8 - Mailbox APIs",
    "description": "Authenticated Gmail mailbox sync, normalized messages, and conflict resolution APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Mailbox APIs",
      "item": [
        {
          "name": "Sync Mailbox",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mailbox\": \"{{mailbox}}\",\n  \"cursor\": null,\n  \"maxResults\": 20\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mail/sync",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mail",
                "sync"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mail/messages?limit=20&cursor={{messagesCursor}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mail",
                "messages"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "cursor",
                  "value": "{{messagesCursor}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Message by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/mail/messages/{{messageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mail",
                "messages",
                "{{messageId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Patch Message Read State",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"read\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mail/messages/{{messageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mail",
                "messages",
                "{{messageId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Resolve Conflict",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{idempotencyKey}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"optionId\": \"delay-pickup\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mail/conflicts/{{conflictId}}/resolve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "mail",
                "conflicts",
                "{{conflictId}}",
                "resolve"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "mailbox",
      "value": "parentosfamily@gmail.com"
    },
    {
      "key": "messageId",
      "value": "gmail-message-001"
    },
    {
      "key": "conflictId",
      "value": "conflict-001"
    },
    {
      "key": "messagesCursor",
      "value": ""
    },
    {
      "key": "idempotencyKey",
      "value": "conflict-001-delay-pickup"
    }
  ]
}
