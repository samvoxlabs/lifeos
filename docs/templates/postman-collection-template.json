{
  "info": {
    "_postman_id": "phase-X-template",
    "name": "Phase X – [Feature Name]",
    "description": "Testing [Feature Name] endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Test Group 1",
      "item": [
        {
          "name": "Test Case 1: [Description]",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"field1\": \"value1\",\n  \"field2\": \"value2\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/endpoint",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "endpoint"]
            }
          },
          "response": []
        },
        {
          "name": "Test Case 2: [Description]",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/endpoint",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "endpoint"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
